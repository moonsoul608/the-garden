DEEPSEEK_API_KEY=

# Absolute public origin used for canonical URLs, social metadata, robots, and
# sitemap entries. Configure the same Production origin in every deployment.
SITE_URL=

# Supabase project values from the project's Connect dialog.
# Use the Preview project locally and in Vercel Preview deployments.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Used by the Supabase CLI's local GitHub provider configuration. Create a
# separate GitHub OAuth app for Preview/local work; never reuse Production.
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=

# Server-only Preview project key used only by the explicit Phase 06C migration
# script. Never expose it to client code or reuse a Production key here.
SUPABASE_SECRET_KEY=
