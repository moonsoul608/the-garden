DEEPSEEK_API_KEY=

# Supabase project values from the project's Connect dialog.
# Use the Preview project locally and in Vercel Preview deployments.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Used by the Supabase CLI's local GitHub provider configuration. Create a
# separate GitHub OAuth app for Preview/local work; never reuse Production.
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=

# Reserved for later server-only administrative or migration work.
# The Auth foundation does not read this value or create a privileged client.
SUPABASE_SECRET_KEY=
