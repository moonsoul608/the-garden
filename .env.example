DEEPSEEK_API_KEY=

# Absolute public origin used for canonical URLs, social metadata, robots, and
# sitemap entries. Configure the same Production origin in every deployment.
SITE_URL=

# Supabase project values from the project's Connect dialog.
# Use the Preview project locally and in Vercel Preview deployments.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public content stays in legacy mode when CONTENT_SOURCE_MODE is absent.
# Source changes are deployment-only and must be adjacent. Set all three values
# together using one of: legacy->dual, dual->database, database->dual, or
# dual->legacy. CONTENT_SOURCE_MODE_CONFIRM must exactly match the target mode.
# Do not enable these values without the approved cutover/rollback runbook.
# CONTENT_SOURCE_MODE=dual
# CONTENT_SOURCE_PREVIOUS_MODE=legacy
# CONTENT_SOURCE_MODE_CONFIRM=dual

# Database-only mode also requires one real control route for each lifecycle.
# The Published route must be present in public collections and details; the
# Draft and Review routes must resolve as not found with legacy fallback
# forbidden; the Archived route must resolve to the resting-state disposition.
# CONTENT_DATABASE_PUBLISHED_PROBE=/garden/published-slug
# CONTENT_DATABASE_DRAFT_PROBE=/garden/draft-control-slug
# CONTENT_DATABASE_REVIEW_PROBE=/forest/review-control-slug
# CONTENT_DATABASE_ARCHIVED_PROBE=/ruins/archived-control-slug

# Used by the Supabase CLI's local GitHub provider configuration. Create a
# separate GitHub OAuth app for Preview/local work; never reuse Production.
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=

# Server-only Preview project key used only by the explicit Phase 06C migration
# script. Never expose it to client code or reuse a Production key here.
SUPABASE_SECRET_KEY=
